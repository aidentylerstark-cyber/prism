<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<panel
        border="true"
        follows="all"
        label="Atmosphere &amp; Lighting"
        layout="topleft"
        left="0"
        name="panel_settings_sky_atmos"
        top="0">
  <string name="hdr_string">HDR Scale:</string>
  <string name="brightness_string">Brightness:</string>
  <string name="hdr_tooltip">Intensity of lighting effects such as realistically bright skies and dynamic exposure. 1.0 is the default, 0 is off, values between 0 and 1 are mixing Ambient with HDR.</string>
  <tab_container name="atmos_tabs"
                 follows="all"
                 layout="topleft"
                 left="0"
                 top="0"
                 right="-1"
                 bottom="-1"
                 tab_position="top"
                 tab_width="140"
                 tab_padding_right="3">
    <panel name="atmos_tab"
           label="Atmosphere &amp; Lighting"
           follows="all"
           layout="topleft"
           left="0"
           top="0">
  <scroll_container
          name="atmos_scroll"
          follows="all"
          layout="topleft"
          left="0"
          top="0"
          right="-1"
          bottom="-1"
          opaque="false"
          reserve_scroll_corner="true">
    <panel
            name="atmos_scroll_panel"
            follows="left|top"
            layout="topleft"
            left="0"
            top="0"
            height="600"
            width="490">
    <layout_stack
            name="main_ls"
            follows="left|top"
            layout="topleft"
            left="5"
            top="5"
            width="480"
            height="590"
            orientation="vertical">
        <layout_panel
                name="top_lp"
                border="true"
                bevel_style="in"
                auto_resize="false"
                user_resize="false"
                visible="true"
                height="75">

            <text
                    name="ambient_color_label"
                    follows="left|top"
                    height="10"
                    layout="topleft"
                    left_delta="15"
                    top_pad="15"
                    width="80">
                Ambient Color:
            </text>
            <color_swatch
                    can_apply_immediately="true"
                    follows="left|top"
                    height="37"
                    label_height="0"
                    layout="topleft"
                    left_delta="0"
                    name="ambient_light"
                    top_pad="5"
                    width="60" />
            <text
                    name="blue_horizon_label"
                    follows="left"
                    height="10"
                    layout="topleft"
                    left_delta="90"
                    top_delta="-15"
                    width="80">
                Blue Horizon:
            </text>
            <color_swatch
                    can_apply_immediately="true"
                    follows="left|top"
                    height="37"
                    label_height="0"
                    layout="topleft"
                    left_delta="0"
                    name="blue_horizon"
                    top_pad="5"
                    width="60" />
            <text
                    name="blue_density_label"
                    follows="left"
                    height="10"
                    layout="topleft"
                    left_delta="90"
                    top_delta="-15"
                    width="80">
                Blue Density:
            </text>
            <color_swatch
                    can_apply_immediately="true"
                    follows="left|top"
                    height="37"
                    label_height="0"
                    layout="topleft"
                    left_delta="0"
                    name="blue_density"
                    top_pad="5"
                    width="60" />
        </layout_panel>
        <layout_panel
                name="bottom_lp"
                border="true"
                bevel_style="in"
                auto_resize="true"
                user_resize="false"
                visible="true">
            <layout_stack name="atmosphere1"
                    left="5"
                    top="5"
                    width="470"
                    height="500"
                    follows="left|top"
                    orientation="vertical">
                <layout_panel
                        name="left_lp"
                        border="false"
                        bevel_style="in"
                        auto_resize="false"
                        user_resize="false"
                        visible="true"
                        height="240">
                    <text
                            name="haze_horizon_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="15"
                            top_pad="15"
                            width="80">
                        Haze Horizon:
                    </text>
                    <slider
                            decimal_digits="2"
                            follows="left|top"
                            height="16"
                            increment="0.01"
                            initial_value="0"
                            layout="topleft"
                            left_delta="5"
                            min_val="0"
                            max_val="5"
                            name="haze_horizon"
                            top_delta="20"
                            width="207"
                            can_edit_text="true"/>
                    <text
                            name="haze_density_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="80">
                        Haze Density:
                    </text>
                    <slider
                            decimal_digits="2"
                            follows="left|top"
                            height="16"
                            increment="0.01"
                            initial_value="0"
                            layout="topleft"
                            left_delta="5"
                            min_val="0"
                            max_val="5"
                            name="haze_density"
                            top_delta="20"
                            width="207"
                            can_edit_text="true"/>
                    <text
                            name="moisture_level_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="80">
                        Moisture Level:
                    </text>
                     <slider
                            decimal_digits="3"
                            follows="left|top"
                            height="14"
                            increment="0.001"
                            initial_value="0"
                            left_delta="5"
                            top_delta="20"
                            layout="topleft"
                            min_val="0"
                            max_val="1"
                            name="moisture_level"
                            width="207"
                            can_edit_text="true"/>
                    <text
                            name="droplet_radius_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="80">
                        Droplet Radius:
                    </text>
                    <slider
                            decimal_digits="2"
                            follows="left|top"
                            height="14"
                            increment="0.01"
                            initial_value="0"
                            left_delta="5"
                            top_delta="20"
                            layout="topleft"
                            min_val="5.0"
                            max_val="1000.0"
                            name="droplet_radius"
                            width="207"
                            can_edit_text="true"/>
                    <text
                            name="ice_level_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="80">
                        Ice Level:
                    </text>
                    <slider
                            decimal_digits="3"
                            follows="left|top"
                            height="14"
                            increment="0.001"
                            initial_value="0"
                            left_delta="5"
                            top_delta="20"
                            layout="topleft"
                            min_val="0"
                            max_val="1"
                            name="ice_level"
                            width="207"
                            can_edit_text="true"/>
                </layout_panel>            
                <layout_panel
                        name="right_lp"
                        border="false"
                        bevel_style="in"
                        auto_resize="false"
                        user_resize="false"
                        visible="true"
                        height="260">
                    <text
                            name="density_multiplier_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="15"
                            top_pad="15"
                            width="200">
                        Density Multiplier:
                    </text>
                    <slider
                            decimal_digits="4"
                            follows="left|top"
                            height="16"
                            increment="0.0001"
                            initial_value="0"
                            layout="topleft"
                            left_delta="5"
                            min_val="0.0001"
                            max_val="2"
                            name="density_multip"
                            top_delta="20"
                            width="219"
                            can_edit_text="true"/>
                    <text
                            name="distance_multiplier_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="200">
                        Distance Multiplier:
                    </text>
                    <slider
                            decimal_digits="2"
                            follows="left|top"
                            height="16"
                            increment="0.01"
                            initial_value="0.8"
                            layout="topleft"
                            left_delta="5"
                            min_val="0.05"
                            max_val="1000"
                            name="distance_multip"
                            top_delta="20"
                            width="219"
                            can_edit_text="true"/>
                    <text
                            name="maximum_altitude_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="200">
                        Maximum Altitude:
                    </text>
                    <slider
                            decimal_digits="2"
                            follows="left|top"
                            height="16"
                            increment="0.01"
                            initial_value="0"
                            layout="topleft"
                            left_delta="5"
                            min_val="0"
                            max_val="10000"
                            name="max_alt"
                            top_delta="20"
                            width="219"
                            can_edit_text="true"/>
                  <text
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            tool_tip="Irradiance control. When not zero, enables HDR lighting model."
                            width="200">
                    Reflection Probe Ambiance (HDR):
                  </text>
                  <slider
                          decimal_digits="2"
                          follows="left|top"
                          height="16"
                          increment="0.01"
                          initial_value="0"
                          layout="topleft"
                          left_delta="5"
                          min_val="0"
                          max_val="10"
                          name="probe_ambiance"
                          tool_tip="Intensity of environment based indirect lighting. At zero HDR scale becomes Brightness"
                          top_delta="20"
                          width="219"
                          can_edit_text="true"/>
                  <text follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            tool_tip="Controls how much sky color contributes to ambient lighting."
                            width="200">
                    Ambient Sky Saturation:
                  </text>
                  <slider
                          decimal_digits="2"
                          follows="left|top"
                          height="16"
                          increment="0.01"
                          initial_value="0"
                          layout="topleft"
                          left_delta="5"
                          min_val="0"
                          max_val="1"
                          name="ambient_sky_saturation"
                          tool_tip="0 = fully desaturated, 1 = full color"
                          top_delta="20"
                          width="219"
                          can_edit_text="true"/>
                  <text
                            name="scene_gamma_label"
                            follows="left|top"
                            height="10"
                            layout="topleft"
                            left_delta="-5"
                            top_delta="25"
                            width="80">
                    Brightness:
                  </text>
                  <slider
                          decimal_digits="2"
                          follows="left|top"
                          height="16"
                          increment="0.01"
                          initial_value="0"
                          layout="topleft"
                          left_delta="5"
                          max_val="20"
                          name="scene_gamma"
                          top_delta="20"
                          width="207"
                          can_edit_text="true"/>
                </layout_panel>            
            </layout_stack>                
        </layout_panel>
    </layout_stack>
    </panel>
  </scroll_container>
    </panel>
    <panel name="post_process_tab"
           label="Post Process"
           follows="all"
           layout="topleft"
           left="0"
           top="0">
        <text
                name="tonemapper_label"
                follows="left|top"
                height="10"
                layout="topleft"
                left_delta="15"
                top_pad="15"
                width="200">
            Tonemapper:
        </text>
        <combo_box
                follows="left|top"
                height="20"
                layout="topleft"
                left_delta="5"
                name="tonemapper"
                top_pad="5"
                width="207">
            <combo_box.item label="Khronos PBR Neutral" name="khronos" value="0"/>
            <combo_box.item label="ACES" name="aces" value="1"/>
        </combo_box>
        <text
                name="tonemap_mix_label"
                follows="left|top"
                height="10"
                layout="topleft"
                left_delta="-5"
                top_pad="10"
                tool_tip="Mix between linear tonemapping (0) and selected tonemapper (1)"
                width="200">
            Tonemapper Mix:
        </text>
        <slider
                decimal_digits="2"
                follows="left|top"
                height="16"
                increment="0.01"
                initial_value="1"
                layout="topleft"
                left_delta="5"
                min_val="0"
                max_val="1"
                name="tonemap_mix"
                tool_tip="0 = Linear tonemapping, 1 = Full tonemapper"
                top_pad="5"
                width="207"
                can_edit_text="true"/>
        <text
                name="hdr_offset_label"
                follows="left|top"
                height="10"
                layout="topleft"
                left_delta="-5"
                top_pad="10"
                width="200">
            HDR Offset:
        </text>
        <slider
                decimal_digits="2"
                follows="left|top"
                height="16"
                increment="0.01"
                initial_value="1"
                layout="topleft"
                left_delta="5"
                min_val="0"
                max_val="2"
                name="hdr_offset"
                top_pad="5"
                width="207"
                can_edit_text="true"/>
        <text
                name="hdr_min_label"
                follows="left|top"
                height="10"
                layout="topleft"
                left_delta="-5"
                top_pad="10"
                width="200">
            HDR Min:
        </text>
        <slider
                decimal_digits="2"
                follows="left|top"
                height="16"
                increment="0.01"
                initial_value="0.5"
                layout="topleft"
                left_delta="5"
                min_val="0"
                max_val="2"
                name="hdr_min"
                top_pad="5"
                width="207"
                can_edit_text="true"/>
        <text
                name="hdr_max_label"
                follows="left|top"
                height="10"
                layout="topleft"
                left_delta="-5"
                top_pad="10"
                width="200">
            HDR Max:
        </text>
        <slider
                decimal_digits="2"
                follows="left|top"
                height="16"
                increment="0.01"
                initial_value="2"
                layout="topleft"
                left_delta="5"
                min_val="0"
                max_val="10"
                name="hdr_max"
                top_pad="5"
                width="207"
                can_edit_text="true"/>
    </panel>
  </tab_container>
</panel>
