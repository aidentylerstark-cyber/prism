	</radio_group>
	<color_swatch label="Cor" name="val_color_swatch"/>
	<spinner label="x" name="val_spinner_1"/>
	<spinner label="x" name="val_spinner_2"/>
	<spinner label="x" name="val_spinner_3"/>
	<spinner label="x" name="val_spinner_4"/>
